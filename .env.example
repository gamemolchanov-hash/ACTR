# ACTR storefront — пример env. Скопируй в .env.local и заполни.
#
# Локальная разработка идёт против ARM-бэкенда из autoCRM-стека (`make up`),
# тенант demo-tenant. Прод-значения — на go-line.

# ARM tenant (X-Tenant-ID). Локально = demo-tenant.
NEXT_PUBLIC_TENANT_ID=demo-tenant

# Storefront API key (X-Storefront-Key). Держать SERVER-SIDE (в Next-прокси),
# НЕ выносить в клиентский бандл. Локальный demo-ключ — в autoCRM tests/conftest.py.
# (Проводка ключа/заголовков ARM — фаза переключения слоя данных, не baseline.)
ARM_STOREFRONT_KEY=

# Общий секрет прокси→BFF (X-Storefront-Proxy-Secret). SERVER-SIDE, НЕ NEXT_PUBLIC_,
# в клиентский бандл не попадает. Пара к X-Storefront-Client-IP: только с этим секретом
# BFF доверяет IP визитора (per-user rate-limit, FBG-390). Пусто — лимитер работает по
# egress-IP. Значение задаёт владелец в /opt/actr/env, в репозиторий НЕ коммитить.
STOREFRONT_PROXY_SECRET=

# ARM BFF base. Локально = autoCRM-стек.
BFF_INTERNAL_URL=http://localhost:4000

# Публичный URL витрины (SEO/canonical).
NEXT_PUBLIC_SITE_URL=http://localhost:3003

# GlitchTip DSN — проект ACTR (#11 на glitchtip.devloc.su). Public (уходит в клиентский бандл).
# Включается ТОЛЬКО при NODE_ENV=production (см. sentry.client.config.ts) — в dev молчит.
NEXT_PUBLIC_STOREFRONT_SENTRY_DSN=https://f5259897f32346beba6e3c1dc3566fb7@glitchtip.devloc.su/11
